# Aurora API – create API key in Aurora Studio → API Keys
NEXT_PUBLIC_AURORA_API_URL=https://api.yourapp.com
AURORA_API_KEY=aur_xxx

# For deploy: set by Aurora when deploying to Vercel
NEXT_PUBLIC_TENANT_SLUG=

# Site branding (optional)
NEXT_PUBLIC_SITE_NAME=My Store
NEXT_PUBLIC_LOGO_URL=

# Catalogue table (optional, defaults to "products")
NEXT_PUBLIC_CATALOG_TABLE=products
